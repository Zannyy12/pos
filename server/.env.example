# Khuzdar POS Backend Environment Configuration Example
# Copy this file to '.env' in this directory and update values for local or production use.

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection (Option A: Connection String - Recommended for Production)
# e.g., postgresql://username:password@hostname:5432/dbname?sslmode=require
DATABASE_URL=

# Database Connection (Option B: Discrete Parameters - Fallback / Local Dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=khuzdarpos

# JWT Auth Secrets (Please replace with long, random keys in production!)
JWT_SECRET=khuzdarpos_secret_key_change_me_in_production_123456
JWT_REFRESH_SECRET=khuzdarpos_refresh_secret_key_change_me_in_production_654321
